---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  showSidebar?: boolean;
}

const { title, description, showSidebar = true } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <script is:inline src="https://unpkg.com/mathjax@3/es5/tex-mml-chtml.js"></script>
    <script is:inline>
      window.MathJax = {
        tex: { inlineMath: [['$', '$'], ['\\(', '\\)']], displayMath: [['$$', '$$'], ['\\[', '\\]']] }
      };
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <div class={`flex-1 ${showSidebar ? 'flex' : ''}`}>
      {showSidebar && <Sidebar />}
      <main class="flex-1 min-w-0">
        <article class="mx-auto max-w-3xl px-6 py-12 prose-custom">
          <slot />
        </article>
      </main>
    </div>
    <Footer />
  </body>
</html>
