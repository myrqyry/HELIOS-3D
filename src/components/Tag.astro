---
export interface Props {
  stage: 'DEMONSTRATED' | 'INFERRED' | 'PROPOSED' | 'SPECULATIVE';
}
const { stage } = Astro.props;

const styles: Record<Props['stage'], string> = {
  DEMONSTRATED: 'bg-gold/15 text-gold',
  INFERRED: 'bg-cyan-2/15 text-cyan-2',
  PROPOSED: 'bg-amber/15 text-amber',
  SPECULATIVE: 'bg-rose/15 text-rose',
};
---
<span class={`inline-block rounded-full px-2 py-0.5 font-mono text-xs font-semibold ${styles[stage]}`}>
  {stage}
</span>
