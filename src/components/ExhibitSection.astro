---
export interface Props {
  eyebrow: string;
  title: string;
  description: string;
  evidenceLabel?: string;
  evidenceHref?: string;
}

const { eyebrow, title, description, evidenceLabel, evidenceHref } = Astro.props;
const titleId = `${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}-title`;
---

<section class="exhibit-section reveal-on-scroll reveal-initial" aria-labelledby={titleId}>
  <div class="exhibit-copy">
    <p class="exhibit-eyebrow">{eyebrow}</p>
    <h2 id={titleId}>{title}</h2>
    <p>{description}</p>
    {evidenceHref && evidenceLabel && (
      <a class="exhibit-evidence-link" href={evidenceHref}>{evidenceLabel}</a>
    )}
  </div>
  <div class="exhibit-visual" role="region" aria-label={`${title} visual`}>
    <slot name="visual" />
    <slot name="fallback" />
  </div>
</section>
