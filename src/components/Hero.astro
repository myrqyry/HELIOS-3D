---
export interface Props {
  title: string;
  subtitle: string;
}
const { title, subtitle } = Astro.props;
---
<header class="relative isolate overflow-hidden">
  <div class="mx-auto max-w-6xl px-6 pt-16 pb-12">
    <h1 class="text-5xl md:text-6xl font-bold text-amber tracking-tight">{title}</h1>
    <p class="mt-4 text-lg text-parchment-2 max-w-2xl">{subtitle}</p>
  </div>
</header>
