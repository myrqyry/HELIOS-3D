---
import { getCollection } from 'astro:content';

const docs = await getCollection('docs');
const computedLastUpdated = docs
  .map((d) => d.data.updated)
  .sort((a, b) => b.getTime() - a.getTime())[0];
const lastUpdated = computedLastUpdated?.toISOString().slice(0, 10) ?? '2026-06-10';
---
<footer class="border-t border-obsidian-3 bg-obsidian mt-auto">
  <div class="mx-auto max-w-6xl px-6 py-6 flex items-center justify-between text-xs text-parchment-2 font-mono">
    <span>HELIOS-3D · 2026</span>
    <a href="https://github.com/myrqyry/HELIOS-3D" class="hover:text-ember">Source on GitHub</a>
    <span>Last updated {lastUpdated}</span>
  </div>
</footer>
