---
import { filterClaims, type ClaimRow } from '../utils/filterClaims';

export interface Props {
  rows: ClaimRow[];
}
const { rows } = Astro.props;

const tags = ['DEMONSTRATED', 'INFERRED', 'PROPOSED', 'SPECULATIVE'] as const;
---
<div
  class="claims-table my-6"
  data-rows={JSON.stringify(rows)}
  data-tags={JSON.stringify(tags)}
>
  <div class="flex flex-wrap gap-2 mb-3">
    {tags.map((tag) => (
      <label class="inline-flex items-center gap-1.5 text-xs font-mono cursor-pointer">
        <input type="checkbox" data-tag={tag} class="accent-ember" />
        <span>{tag}</span>
      </label>
    ))}
    <button data-reset class="text-xs text-parchment-2 hover:text-ember ml-2">Reset</button>
  </div>
  <table class="w-full text-sm border-collapse">
    <thead>
      <tr class="border-b border-obsidian-3 text-left text-amber font-mono text-xs uppercase">
        <th class="py-2 pr-3">Claim</th>
        <th class="py-2 pr-3">Tag</th>
        <th class="py-2">Source</th>
      </tr>
    </thead>
    <tbody data-body>
      {rows.map((row) => (
        <tr class="border-b border-obsidian-3" data-tag={row.tag}>
          <td class="py-2 pr-3 text-parchment">{row.claim}</td>
          <td class="py-2 pr-3 font-mono text-xs text-amber">{row.tag}</td>
          <td class="py-2 text-parchment-2">{row.source}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<script is:inline>
  document.querySelectorAll('.claims-table').forEach((root) => {
    const body = root.querySelector('[data-body]');
    const checkboxes = root.querySelectorAll('input[type="checkbox"]');
    const reset = root.querySelector('[data-reset]');
    const apply = () => {
      const selected = Array.from(checkboxes).filter((c) => c.checked).map((c) => c.getAttribute('data-tag'));
      body.querySelectorAll('tr[data-tag]').forEach((tr) => {
        tr.style.display = selected.length === 0 || selected.includes(tr.getAttribute('data-tag')) ? '' : 'none';
      });
    };
    checkboxes.forEach((c) => c.addEventListener('change', apply));
    reset.addEventListener('click', () => { checkboxes.forEach((c) => (c.checked = false)); apply(); });
  });
</script>
