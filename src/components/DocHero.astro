---
import StageBadge, { type DocStage } from './StageBadge.astro';
import Tag from './Tag.astro';

export interface Props {
  title: string;
  summary: string;
  stage: DocStage;
  tags: Array<'DEMONSTRATED' | 'INFERRED' | 'PROPOSED' | 'SPECULATIVE'>;
  updated: Date;
}

const { title, summary, stage, tags, updated } = Astro.props;
const updatedStr = updated.toISOString().slice(0, 10);
---
<header class="mb-8 pb-6 border-b border-obsidian-3">
  <div class="flex items-center gap-3 mb-3">
    <StageBadge stage={stage} />
    <span class="font-mono text-xs text-parchment-2">Updated {updatedStr}</span>
  </div>
  <h1 class="text-5xl font-bold text-amber mb-3 leading-tight">{title}</h1>
  <p class="text-lg text-parchment-2 max-w-2xl">{summary}</p>
  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-1.5">
      {tags.map((t) => <Tag stage={t} />)}
    </div>
  )}
</header>
