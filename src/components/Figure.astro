---
export interface Props {
  src: string;
  alt: string;
  caption?: string;
  width?: number;
  height?: number;
}
const { src, alt, caption, width = 1200, height = 800 } = Astro.props;
---
<figure class="my-6">
  <img src={src} alt={alt} width={width} height={height} class="w-full rounded-lg border border-obsidian-3" loading="lazy" decoding="async" />
  {caption && <figcaption class="mt-2 text-sm text-parchment-2 text-center">{caption}</figcaption>}
</figure>
