---
export interface Props {
  type?: 'info' | 'warning' | 'note';
  title?: string;
}
const { type = 'info', title } = Astro.props;

const palette = {
  info: 'border-amber bg-obsidian-2',
  warning: 'border-rose bg-obsidian-2',
  note: 'border-cyan-2 bg-obsidian-2',
};
---
<aside class={`my-4 rounded-lg border-l-4 p-4 ${palette[type]}`}>
  {title && <p class="font-bold text-parchment mb-1">{title}</p>}
  <div class="text-parchment-2 text-sm">
    <slot />
  </div>
</aside>
