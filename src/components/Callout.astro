---
export interface Props {
  type?: 'info' | 'warning' | 'note';
  title?: string;
}
const { type = 'info', title } = Astro.props;

const palette = {
  info: 'border-primary bg-primary/5',
  warning: 'border-error bg-error/5',
  note: 'border-cyan-2 bg-cyan-2/5',
};
---
<aside class={`my-4 rounded-xl border-l-4 p-4 ${palette[type]}`}>
  {title && <p class="font-bold text-on-surface mb-1">{title}</p>}
  <div class="text-on-surface-variant text-sm">
    <slot />
  </div>
</aside>
