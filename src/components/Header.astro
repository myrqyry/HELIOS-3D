---
const nav = [
  { href: '/', label: 'Home' },
  { href: '/start-here/', label: 'Start Here' },
  { href: '/docs/established/abstract/', label: 'Docs' },
  { href: '/figures/', label: 'Figures' },
  { href: '/docs/project-ops/deployment/', label: 'Deploy' },
];
---
<header class="sticky top-0 z-50 border-b border-obsidian-3/30 bg-obsidian/70 backdrop-blur-md transition-all duration-300">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
    <a href="/" class="font-mono text-amber text-lg font-bold tracking-wider hover:text-ember transition-colors flex items-center gap-2">
      <span class="text-xl animate-pulse">☀️</span>HELIOS-3D
    </a>
    <div class="flex items-center gap-6">
      <nav class="flex gap-6 text-sm font-medium">
        {nav.map((item) => (
          <a href={item.href} class="text-parchment-2 hover:text-ember transition-all duration-200 relative py-1 group">
            {item.label}
            <span class="absolute bottom-0 left-0 w-0 h-[2px] bg-gradient-to-r from-amber to-ember transition-all duration-300 group-hover:w-full"></span>
          </a>
        ))}
      </nav>
      <select
        data-stage-filter
        class="font-mono text-xs bg-obsidian-2/60 border border-obsidian-3/60 text-parchment rounded px-2.5 py-1 focus:outline-none focus:border-ember transition-colors"
        aria-label="Filter docs by stage"
      >
        <option value="all">All stages</option>
        <option value="established">Established</option>
        <option value="current">Current</option>
        <option value="speculative">Speculative</option>
        <option value="project-ops">Project Ops</option>
      </select>
    </div>
  </div>
</header>
<script is:inline>
  (() => {
    const sel = document.querySelector('[data-stage-filter]');
    if (!sel) return;
    const STORAGE_KEY = 'helios-3d-stage-filter';
    const saved = localStorage.getItem(STORAGE_KEY) || 'all';
    sel.value = saved;
    sel.addEventListener('change', (e) => {
      const value = e.target.value;
      localStorage.setItem(STORAGE_KEY, value);
      const root = document.documentElement;
      if (value === 'all') root.removeAttribute('data-stage');
      else root.setAttribute('data-stage', value);
    });
    if (saved !== 'all') document.documentElement.setAttribute('data-stage', saved);
  })();
</script>
