---
import StageBadge from '../StageBadge.astro';
import type { ResearchRecord } from '../../data/research-ingestion';

export interface Props {
  records: ResearchRecord[];
  detailBasePath?: string;
}

const { records, detailBasePath = '/research' } = Astro.props as Props;

const dateFormatter = new Intl.DateTimeFormat('en', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

function formatDate(value: string): string {
  return dateFormatter.format(new Date(value));
}
---

<section class="rounded-xl border border-obsidian-3 bg-obsidian-2 p-6">
  <div class="mb-5 space-y-3">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div class="space-y-2">
        <h2 class="text-2xl font-bold text-amber">Research browser</h2>
        <p class="max-w-3xl text-parchment-2 leading-relaxed">
          Search the normalized research records locally, then open a stable
          detail page for any entry that matters.
        </p>
      </div>
      <label class="flex w-full max-w-md flex-col gap-2 text-sm text-parchment-2">
        <span class="font-mono uppercase tracking-wider text-xs text-amber">Filter records</span>
        <input
          name="research-search"
          type="search"
          data-research-search
          autocomplete="off"
          spellcheck="false"
          placeholder="Search title, source, summary, or tags…"
          class="rounded-lg border border-obsidian-3 bg-obsidian-1 px-4 py-2 text-parchment placeholder:text-parchment-2/60 outline-none transition-colors focus-visible:border-amber focus-visible:ring-2 focus-visible:ring-amber focus-visible:ring-offset-2 focus-visible:ring-offset-obsidian"
        />
      </label>
    </div>
  </div>

  <div data-research-browser-root>
    <div class="grid gap-4 md:grid-cols-2">
      {records.map((record) => (
        <article
          class="rounded-lg border border-obsidian-3/60 bg-obsidian-1/40 p-5"
          data-research-card
          data-search-text={`${record.id} ${record.title} ${record.source} ${record.summary} ${record.tags.join(' ')} ${record.publicUse} ${record.evidenceLevel}`.toLowerCase()}
        >
          <div class="mb-3 flex flex-wrap items-start justify-between gap-3">
            <StageBadge stage={record.stage} size="sm" />
            <time class="font-mono text-xs uppercase tracking-wider text-parchment-2" datetime={record.publishedAt}>
              {formatDate(record.publishedAt)}
            </time>
          </div>

          <h3 class="text-xl font-bold text-amber">{record.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-parchment-2">{record.summary}</p>

          <div class="mt-4 flex flex-wrap gap-2 text-[11px] uppercase tracking-wider text-parchment-2">
            {record.tags.map((tag) => (
              <span class="rounded-full border border-obsidian-3 px-2 py-1">{tag}</span>
            ))}
          </div>

          <div class="mt-4 flex items-center justify-between gap-3 text-xs uppercase tracking-wider text-parchment-2">
            <span>Source: {record.source}</span>
            <a class="text-amber hover:text-ember hover:underline" href={`${detailBasePath}/${record.id}/`}>
              Open detail
            </a>
          </div>
        </article>
      ))}
    </div>

    <p data-research-empty class="mt-6 hidden rounded-lg border border-obsidian-3 bg-obsidian-1/60 p-4 text-sm text-parchment-2">
      No records match this search.
    </p>
  </div>
</section>

<script>
  const root = document.querySelector('[data-research-browser-root]');
  const input = document.querySelector('[data-research-search]') as HTMLInputElement | null;
  const cards = root ? Array.from(root.querySelectorAll('[data-research-card]')) : [];
  const empty = root ? root.querySelector('[data-research-empty]') : null;

  function syncUrl(query: string) {
    const url = new URL(window.location.href);
    if (query) {
      url.searchParams.set('q', query);
    } else {
      url.searchParams.delete('q');
    }
    window.history.replaceState({}, '', url);
  }

  function updateVisibility() {
    const query = String(input?.value ?? '').trim().toLowerCase();
    const terms = query.length === 0 ? [] : query.split(/\s+/).filter(Boolean);
    let visibleCount = 0;

    cards.forEach((card) => {
      const searchable = String(card.getAttribute('data-search-text') ?? '');
      const visible = terms.length === 0 || terms.every((term) => searchable.includes(term));
      card.toggleAttribute('hidden', !visible);
      if (visible) visibleCount += 1;
    });

    if (empty) {
      empty.toggleAttribute('hidden', visibleCount !== 0);
    }

    syncUrl(query);
  }

  const initialQuery = new URL(window.location.href).searchParams.get('q');
  if (input && initialQuery) {
    input.value = initialQuery;
  }

  input?.addEventListener('input', updateVisibility);
  updateVisibility();
</script>
