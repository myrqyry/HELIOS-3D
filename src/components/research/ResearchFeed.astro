---
import StageBadge from '../StageBadge.astro';
import { getResearchRecordsByUse, type ResearchRecord, type ResearchUse } from '../../data/research-ingestion';

export interface Props {
  use: ResearchUse;
  title: string;
  summary: string;
  limit?: number;
  compact?: boolean;
}

const { use, title, summary, limit = 3, compact = false } = Astro.props as Props;

const dateFormatter = new Intl.DateTimeFormat('en', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

function isRenderableRecord(record: ResearchRecord): boolean {
  return record.title.trim().length > 0 && record.source.trim().length > 0 && !Number.isNaN(Date.parse(record.publishedAt));
}

const records = getResearchRecordsByUse(use).filter(isRenderableRecord).slice(0, limit);

function formatDate(value: string): string {
  return dateFormatter.format(new Date(value));
}
---

<section class={`rounded-xl border border-obsidian-3 bg-obsidian-2 ${compact ? 'p-4' : 'p-6'}`}>
  <div class={`mb-5 ${compact ? 'space-y-2' : 'space-y-3'}`}>
    <h2 class={`font-bold text-amber ${compact ? 'text-xl' : 'text-2xl'}`}>{title}</h2>
    <p class="max-w-3xl text-parchment-2 leading-relaxed">{summary}</p>
  </div>

  {records.length > 0 ? (
    <div class={`grid gap-4 ${compact ? '' : 'md:grid-cols-2'}`}>
      {records.map((record) => (
        <article class={`rounded-lg border border-obsidian-3/60 bg-obsidian-1/40 ${compact ? 'p-4' : 'p-5'}`}>
          <div class="mb-3 flex flex-wrap items-start justify-between gap-3">
            <StageBadge stage={record.stage} size="sm" />
            <time class="font-mono text-xs uppercase tracking-wider text-parchment-2" datetime={record.publishedAt}>
              {formatDate(record.publishedAt)}
            </time>
          </div>

          <h3 class={`font-bold text-amber ${compact ? 'text-lg' : 'text-xl'}`}>{record.title}</h3>
          <p class={`mt-2 leading-relaxed text-parchment-2 ${compact ? 'text-sm' : ''}`}>{record.summary}</p>

          <div class="mt-4 flex flex-wrap items-center justify-between gap-3 text-xs uppercase tracking-wider text-parchment-2">
            <span>Source: {record.source}</span>
            {record.url ? (
              <a href={record.url} class="text-amber hover:text-ember hover:underline">
                Read source
              </a>
            ) : null}
          </div>
        </article>
      ))}
    </div>
  ) : (
    <p class="text-sm text-parchment-2">No public records are available for this feed.</p>
  )}
</section>
