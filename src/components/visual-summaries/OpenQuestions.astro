---
const blockers = [
  {
    section: 'Materials & Fabrication',
    items: [
      { title: 'Conformal vdW Deposition', stage: 'speculative', body: 'Can high-quality vdW ferromagnets like Fe₃GaTe₂ maintain magnetic anisotropy when applied via ALD over complex 3D DISH/TPP scaffolds?', unblock: 'Repeatable conformal film quality on non-flat substrates.' },
      { title: 'Thermal Expansion Mismatch', stage: 'speculative', body: 'Differential expansion between polymer scaffolds and magnetic coatings may cause delamination during thermal cycling.', unblock: 'Matched-CTE scaffold material or compliant buffer layers.' },
      { title: 'Y-zipper Alignment', stage: 'proposed', body: 'Can the 3D-printed zipping process achieve the sub-micron alignment precision required for continuous spintronic interconnects?', unblock: 'Sub-µm alignment in a zipped rod.' },
      { title: 'Moiré Reproducibility', stage: 'proposed', body: 'Cornell\'s strain-induced moiré (2026) mitigates manual twisting disorder. Calibration for magnetic vdW materials remains unverified.', unblock: 'Calibrated strain-induced moiré on Fe₃GaTe₂.' },
    ],
  },
  {
    section: 'Core Logic & Stochasticity',
    items: [
      { title: 'BRC Signal-to-Noise', stage: 'speculative', body: 'What is the minimum population density required for ensemble accuracy? Can we distinguish ReLU-like transforms from pure noise?', unblock: 'Demonstrated ensemble accuracy ≥ baseline on a standard benchmark.' },
      { title: 'MCA Readout Latency', stage: 'proposed', body: 'Does the overhead of microwave signal processing (RF shielding, ADC/DAC) nullify the energy gains of the spintronic core?', unblock: 'End-to-end latency budget that beats the 28nm CMOS comparator.' },
    ],
  },
  {
    section: 'Topological Stability',
    items: [
      { title: 'Hopfion Nucleation Barrier', stage: 'demonstrated', body: 'EuS/Bi₂Se₃/EuS trilayers show zero-field stability at 300 K. Barriers for sub-100nm confined 3D geometries remain unverified.', unblock: 'Measured annihilation barrier ≥ 50 k_B T in a multi-gate MCA device.' },
      { title: 'Data Center Stability', stage: 'speculative', body: 'Is topological protection sufficient at T > 350 K? Requires binding energy E_B > 50 k_B T at max operating temperature.', unblock: 'Stability measurements at 358 K with measured E_B.' },
      { title: 'Skyrmion-to-Hopfion Path', stage: 'proposed', body: 'Is the transformation from 2D strings to 3D knots topologically allowed without destroying the spin texture?', unblock: 'A demonstrated skyrmion → hopfion transition.' },
      { title: 'Super-Moiré Textures', stage: 'proposed', body: 'How does protection translate in non-planar geometries? Can stressor films be applied conformally to a DISH scaffold?', unblock: 'Strain-engineered moiré on a non-flat surface.' },
    ],
  },
];
const stageColor: Record<string, string> = {
  speculative: 'text-rose border-rose',
  proposed: 'text-amber border-amber',
  demonstrated: 'text-gold border-gold',
  inferred: 'text-cyan-2 border-cyan-2',
};
const stageLabel: Record<string, string> = {
  speculative: 'SPECULATIVE',
  proposed: 'PROPOSED',
  demonstrated: 'DEMONSTRATED',
  inferred: 'INFERRED',
};
---
<section class="my-12 space-y-10">
  {blockers.map((section) => (
    <div>
      <p class="font-mono text-xs uppercase tracking-wider text-amber mb-4">{section.section}</p>
      <div class="grid md:grid-cols-2 gap-4">
        {section.items.map((b) => (
          <article class="rounded-lg border border-obsidian-3 bg-obsidian-2 p-5">
            <div class="flex items-start justify-between gap-3 mb-2">
              <h3 class="text-amber font-bold text-lg leading-tight">{b.title}</h3>
              <span class={`shrink-0 font-mono text-[10px] px-2 py-0.5 rounded border uppercase tracking-wider ${stageColor[b.stage]}`}>
                {stageLabel[b.stage]}
              </span>
            </div>
            <p class="text-sm text-parchment-2 mb-3">{b.body}</p>
            <p class="text-xs border-t border-obsidian-3 pt-2 mt-auto"><span class="text-parchment-2 font-mono uppercase">Unblock: </span><span class="text-amber">{b.unblock}</span></p>
          </article>
        ))}
      </div>
    </div>
  ))}

  <div class="rounded-lg border border-obsidian-3 bg-obsidian-2 p-6">
    <p class="font-mono text-xs uppercase tracking-wider text-amber mb-3">Minimum Viable Demonstrator (MVD) sequence</p>
    <ol class="space-y-2 text-sm">
      <li class="flex gap-3"><span class="font-mono text-amber shrink-0">I.</span><span class="text-parchment-2"><span class="text-amber font-bold">Materials:</span> Fe₃GaTe₂ on a TPP-refined surface with MFM verification.</span></li>
      <li class="flex gap-3"><span class="font-mono text-amber shrink-0">II.</span><span class="text-parchment-2"><span class="text-amber font-bold">MCA Logic:</span> Single-track domain wall displacement driven by SOT with microwave readout.</span></li>
      <li class="flex gap-3"><span class="font-mono text-amber shrink-0">III.</span><span class="text-parchment-2"><span class="text-amber font-bold">BRC Stochasticity:</span> Skyrmion Brownian motion in a confined polymer micro-harbor.</span></li>
      <li class="flex gap-3"><span class="font-mono text-amber shrink-0">IV.</span><span class="text-parchment-2"><span class="text-amber font-bold">Integration:</span> 3D routing between a single MCA gate and a single BRC reservoir.</span></li>
    </ol>
  </div>
</section>
