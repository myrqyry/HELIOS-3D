---
const terms = [
  { name: 'AHE', full: 'Anomalous Hall Effect', desc: 'A geometric contribution to the Hall effect from Berry curvature in ferromagnets. Used for electrical readout of skyrmion/hopfion positions.' },
  { name: 'Berry Curvature', full: '', desc: 'A geometric property of a material\'s band structure that acts as an effective magnetic field in momentum space. Key to Fe₃GaTe₂\'s magnetic properties.' },
  { name: 'BRC', full: 'Brownian Reservoir Computing', desc: 'HELIOS-3D\'s probabilistic core. Uses ambient thermal noise (Brownian motion) to drive skyrmion dynamics in confined geometries.' },
  { name: 'CISS', full: 'Chiral-Induced Spin Selectivity', desc: 'Spin-dependent electron transmission through chiral molecules. Demonstrated in 2026 (Vardi et al.) for isotopic fractionation.' },
  { name: 'DMI', full: 'Dzyaloshinskii-Moriya Interaction', desc: 'Antisymmetric exchange that favors chiral spin twists. The foundational energy term enabling skyrmion/hopfion formation.' },
  { name: 'DISH', full: 'Digital Incoherent Synthesis of Holographic light fields', desc: 'Volumetric 3D printing using holographic projection. 0.6 s curing, 19 µm resolution, single-side illumination.' },
  { name: 'ERC', full: 'Ensemble Reservoir Computing', desc: 'Spatial multiplexing of thousands of independent reservoirs to average out noise. Target: 98% accuracy.' },
  { name: 'hBN', full: 'Hexagonal Boron Nitride', desc: '2D vdW material. Monolayer hBN with V_B⁻ defects proposed as a quantum sensor for magnetic texture readout (replaces NV centers).' },
  { name: 'IFE', full: 'Inverse Faraday Effect', desc: 'Non-linear magneto-optical effect where circularly polarized light induces static magnetization. Primary mechanism for all-optical writing of hopfions.' },
  { name: 'Hopfion', full: '', desc: 'A 3D topological magnetic soliton — a knot in the magnetization field characterized by the Hopf invariant Q_H. Projects to zero 2D charge, bypassing the SkHE.' },
  { name: 'LLG', full: 'Landau-Lifshitz-Gilbert', desc: 'Continuum equation describing magnetization dynamics. Used in MuMax3/OOMMF simulations of skyrmion and hopfion motion.' },
  { name: 'MCA', full: 'Magnetic Convolutional Accelerator', desc: 'HELIOS-3D\'s deterministic CiM architecture using spin-orbit torque to drive domain walls for arithmetic operations.' },
  { name: 'MTJ', full: 'Magnetic Tunnel Junction', desc: 'Two ferromagnetic layers separated by an insulating barrier. Exhibits TMR. Used for electrical readout.' },
  { name: 'PMA', full: 'Perpendicular Magnetic Anisotropy', desc: 'Easy axis perpendicular to the film plane. Essential for stabilizing skyrmions and hopfions at room temperature. Fe₃GaTe₂ exhibits strong PMA.' },
  { name: 'PINN', full: 'Physics-Informed Neural Network', desc: 'Deep learning models that encode physical laws (PDEs) into their loss functions. Used for high-speed micromagnetic synthesis.' },
  { name: 'SAF', full: 'Synthetic Antiferromagnet', desc: 'Two ferromagnetic layers coupled antiferromagnetically via a non-magnetic spacer (e.g., Ru). Reduces stray fields.' },
  { name: 'SkHE', full: 'Skyrmion Hall Effect', desc: 'Transverse deflection of skyrmions relative to driving current. Hopfions bypass this due to zero 2D projection charge.' },
  { name: 'SOT', full: 'Spin-Orbit Torque', desc: 'Spin-current-induced torque that drives domain wall or skyrmion motion. More energy-efficient than charge-current driving.' },
  { name: 'THE', full: 'Topological Hall Effect', desc: 'Additional Hall contribution from real-space Berry curvature of non-collinear spin textures. Used to detect skyrmion presence.' },
  { name: 'TLP', full: 'Toroidal Light Pulse', desc: 'Space-time non-separable electromagnetic pulse with toroidal topology ("flying doughnut"). Proposed as a topological bus for inter-module communication.' },
  { name: 'TOHE', full: 'Topological Orbital Hall Effect', desc: '3D transverse current of orbital angular momentum generated by electrons passing through a 3D topological spin texture. The electronic hallmark for hopfions.' },
  { name: 'TPP', full: 'Two-Photon Polymerization', desc: 'Laser-based 3D microfabrication with sub-100 nm resolution. Proposed for refining scaffold features after DISH.' },
  { name: 'vdW', full: 'van der Waals', desc: 'Weak interlayer forces in 2D materials. Fe₃GaTe₂ is a layered ferromagnet with vdW interlayer bonding.' },
  { name: 'V_B⁻', full: 'Negatively Charged Boron Vacancy', desc: 'Point defect in hBN that acts as a room-temperature quantum sensor. Alternative to diamond NV centers.' },
  { name: 'Y-zipper', full: '', desc: '3D-printed flexible-rigid transition mechanism using interlocking strips. For deployable or reconfigurable spintronic scaffolds.' },
];
---
<section class="my-12">
  <p class="text-parchment-2 text-lg max-w-3xl mb-8">
    Terms used across topological physics, spintronic device engineering, and reservoir computing. Alphabetized.
  </p>
  <div class="grid md:grid-cols-3 gap-4">
    {terms.map((t) => (
      <article class="rounded-lg border border-obsidian-3 bg-obsidian-2 p-4">
        <h3 class="text-amber font-bold font-mono text-base mb-1">{t.name}</h3>
        {t.full && <p class="font-mono text-xs text-parchment-2 mb-2">{t.full}</p>}
        <p class="text-sm text-parchment-2">{t.desc}</p>
      </article>
    ))}
  </div>
</section>
