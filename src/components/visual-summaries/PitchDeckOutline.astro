---
import HopfionScene from '../r3f/HopfionScene';
const slides = [
  { n: 1, title: 'The Thermodynamic & Environmental Wall', bullets: ['AI power: trajectory to >1,000 TWh by 2026', 'Water withdrawal: billions of m³ by 2027', 'Physical limit: Joule heating + embodied carbon', 'Motivation: bridge silicon-to-biological efficiency gap'] },
  { n: 2, title: 'The HELIOS-3D Hypothesis', bullets: ['Hybrid-manufactured Energy-Landscape Inference and Operation System', 'Carrier shift: charge → topologically protected 3D spin textures', 'Energy flip: investigate "spin caloritronics" — heat as locomotive force'] },
  { n: 3, title: 'Proposed Dual-Core Architecture', bullets: ['MCA: deterministic Compute-in-Memory via Spin-Orbit Torque', 'BRC: stochastic, noise-driven decision-making in micro-confined reservoirs', 'Aspirational target: fJ-scale switching energy'] },
  { n: 4, title: 'A Proposed Fabrication Pathway', bullets: ['DISH: rapid holographic instantiation of non-magnetic scaffolds', 'TPP: sub-100 nm precision refinement of routing tracks', 'ALD: hypothesized conformal coating of vdW ferromagnets (Fe₃GaTe₂)'] },
  { n: 5, title: 'The Strategic Potential', bullets: ['Energy efficiency: target reductions in energy per operation', 'Area density: theoretical gains via 3D topological volumetric scaling', 'Functional throughput: hypothesized high-throughput inference for specialized AI'] },
  { n: 6, title: 'Strategic Sustainability', bullets: ['Energy-proportional computing: zero leakage via non-volatile magnetic states', 'Resource efficiency: "atomic logic" replaces bulk silicon + cooling cycles', 'ESG alignment: 2030 carbon and water neutrality mandates'] },
];
---
<section class="my-12 space-y-8">
  <p class="text-parchment-2 text-lg max-w-3xl">
    The 6-slide pitch outline. The current recommended demonstrator path is documented in <a href="/docs/current/alternative-materials-and-methods/" class="text-amber hover:underline">Alternative Materials and Methods</a> — the pitch describes the long-range research vision.
  </p>

  <ol class="space-y-4">
    {slides.map((s) => (
      <li class="rounded-lg border border-obsidian-3 bg-obsidian-2 p-5 grid grid-cols-[auto_1fr] gap-5 items-start">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-obsidian border-2 border-amber">
          <span class="font-mono text-amber text-lg">{String(s.n).padStart(2, '0')}</span>
        </div>
        <div>
          <h3 class="text-amber font-bold text-lg mb-2">{s.title}</h3>
          <ul class="space-y-1 text-sm text-parchment-2">
            {s.bullets.map((b) => <li>· {b}</li>)}
          </ul>
        </div>
      </li>
    ))}
  </ol>

  <div class="my-8">
    <HopfionScene client:visible height="h-56" />
    <p class="mt-2 text-center text-xs text-parchment-2 font-mono">The carrier at the heart of the pitch. Stylized illustration — not simulation-accurate.</p>
  </div>
</section>
