---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HopfionScene from '../components/r3f/HopfionScene';
import SkyrmionScene from '../components/r3f/SkyrmionScene';
import MaterialStack from '../components/r3f/MaterialStack';
import DmiChirality from '../components/r3f/DmiChirality';
import TwistReservoirNucleation from '../components/r3f/TwistReservoirNucleation';
import TopologicalOrbitalHall from '../components/r3f/TopologicalOrbitalHall';
import BreathingModeSpectrum from '../components/charts/BreathingModeSpectrum';
import EnergyBarrier from '../components/charts/EnergyBarrier';
import LiteratureTimeline from '../components/charts/LiteratureTimeline';
import PerformanceFloor from '../components/charts/PerformanceFloor';

const figures = await getCollection('figures');

const allSources = Array.from(new Set(figures.map((f) => f.data.source)));
const allKinds = Array.from(new Set(figures.map((f) => f.data.kind)));
---
<BaseLayout title="Figures" description="All visualizations in the HELIOS-3D site.">
  <header class="mb-8 pb-6 border-b border-obsidian-3">
    <h1 class="text-5xl font-bold text-amber mb-3">Figures</h1>
    <p class="text-lg text-parchment-2 max-w-2xl">Every visualization used in the site, grouped by source and kind.</p>
  </header>
  <div class="mb-8 flex flex-wrap gap-2" data-figures-filters>
    <div class="flex items-center gap-2 mr-4">
      <span class="font-mono text-xs uppercase text-parchment-2">Source</span>
      <button data-filter-source="all" class="font-mono text-xs px-3 py-1 rounded border border-obsidian-3 bg-obsidian-2 text-amber">All</button>
      {allSources.map((s) => (
        <button data-filter-source={s} class="font-mono text-xs px-3 py-1 rounded border border-obsidian-3 text-parchment-2 hover:text-amber">{s}</button>
      ))}
    </div>
    <div class="flex items-center gap-2">
      <span class="font-mono text-xs uppercase text-parchment-2">Kind</span>
      <button data-filter-kind="all" class="font-mono text-xs px-3 py-1 rounded border border-obsidian-3 bg-obsidian-2 text-amber">All</button>
      {allKinds.map((k) => (
        <button data-filter-kind={k} class="font-mono text-xs px-3 py-1 rounded border border-obsidian-3 text-parchment-2 hover:text-amber">{k}</button>
      ))}
    </div>
  </div>
  <div class="grid md:grid-cols-2 gap-8" data-figures-grid>
    {figures.map((f) => (
      <article
        class="glass-card rounded-xl p-5 flex flex-col justify-between group overflow-hidden"
        data-source={f.data.source}
        data-kind={f.data.kind}
      >
        <div>
          <div class="relative rounded-lg overflow-hidden border border-obsidian-3/45 bg-obsidian/30 shadow-inner">
            {f.data.component === 'HopfionScene' && <HopfionScene client:visible height="h-48" />}
            {f.data.component === 'SkyrmionScene' && <SkyrmionScene client:visible height="h-48" />}
            {f.data.component === 'MaterialStack' && <MaterialStack client:visible height="h-48" />}
            {f.data.component === 'DmiChirality' && <DmiChirality client:visible height="h-48" />}
            {f.data.component === 'TwistReservoirNucleation' && <TwistReservoirNucleation client:visible height="h-48" />}
            {f.data.component === 'TopologicalOrbitalHall' && <TopologicalOrbitalHall client:visible height="h-48" />}
            {f.data.component === 'BreathingModeSpectrum' && <BreathingModeSpectrum client:visible height="h-48" />}
            {f.data.component === 'EnergyBarrier' && <EnergyBarrier client:visible height="h-48" />}
            {f.data.component === 'LiteratureTimeline' && <LiteratureTimeline client:visible height="h-48" />}
            {f.data.component === 'PerformanceFloor' && <PerformanceFloor client:visible height="h-48" />}
          </div>
          <h3 class="mt-4 font-bold text-amber text-lg group-hover:text-ember transition-colors">{f.data.title}</h3>
          <p class="text-sm text-parchment-2/90 mt-1.5 leading-relaxed">{f.data.description}</p>
        </div>
        <p class="text-xs font-mono text-parchment-2/80 mt-4 pt-3 border-t border-obsidian-3/30 flex items-center justify-between">
          <span>Source: <span class={f.data.source === 'data-driven' ? 'text-gold font-semibold' : 'text-cyan-2 font-semibold'}>{f.data.source}</span></span>
          <span class="px-2 py-0.5 bg-obsidian-2 rounded-full border border-obsidian-3/40 text-[10px] uppercase tracking-wider">{f.data.kind}</span>
        </p>
      </article>
    ))}
  </div>
</BaseLayout>
<script>
  const grid = document.querySelector('[data-figures-grid]');
  const filterButtons = document.querySelectorAll('[data-figures-filters] button');
  if (grid) {
    let sourceFilter: string = 'all';
    let kindFilter: string = 'all';
    const applyFilters = () => {
      const cards = grid.querySelectorAll('article');
      cards.forEach((card) => {
        const s = card.getAttribute('data-source');
        const k = card.getAttribute('data-kind');
        const show = (sourceFilter === 'all' || s === sourceFilter) && (kindFilter === 'all' || k === kindFilter);
        (card as HTMLElement).style.display = show ? '' : 'none';
      });
    };
    filterButtons.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const t = e.currentTarget as HTMLButtonElement;
        if (t.hasAttribute('data-filter-source')) {
          sourceFilter = t.getAttribute('data-filter-source') || 'all';
          document.querySelectorAll('[data-filter-source]').forEach((b) => b.classList.remove('bg-obsidian-2', 'text-amber'));
          t.classList.add('bg-obsidian-2', 'text-amber');
        }
        if (t.hasAttribute('data-filter-kind')) {
          kindFilter = t.getAttribute('data-filter-kind') || 'all';
          document.querySelectorAll('[data-filter-kind]').forEach((b) => b.classList.remove('bg-obsidian-2', 'text-amber'));
          t.classList.add('bg-obsidian-2', 'text-amber');
        }
        applyFilters();
      });
    });
  }
</script>
