---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TOC from '../../../components/TOC.astro';
import DocHero from '../../../components/DocHero.astro';
import { figureMap } from '../../../utils/figureMap';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((doc) => ({
    params: { stage: doc.data.stage, slug: doc.id.split('/').pop()?.replace(/\.mdx?$/, '') ?? doc.id },
    props: { doc },
  }));
}

interface Props { doc: CollectionEntry<'docs'> }
const { doc } = Astro.props;
const { Content, headings } = await doc.render();

const heroFigureSlug = doc.data.figures[0];
const HeroScene = heroFigureSlug ? figureMap[heroFigureSlug] : null;
---
<BaseLayout title={doc.data.title} description={doc.data.summary}>
  <DocHero
    title={doc.data.title}
    summary={doc.data.summary}
    stage={doc.data.stage}
    tags={doc.data.tags}
    updated={doc.data.updated}
  />
  {HeroScene && (
    <div class="my-8">
      <HeroScene client:visible height="h-96" />
      <p class="mt-2 text-center text-xs text-parchment-2 font-mono">Stylized illustration — not simulation-accurate.</p>
    </div>
  )}
  <TOC headings={headings} />
  <Content />
  <footer class="mt-12 pt-4 border-t border-obsidian-3 text-xs text-parchment-2 font-mono">
    Last updated: {doc.data.updated.toISOString().slice(0, 10)}
  </footer>
</BaseLayout>
