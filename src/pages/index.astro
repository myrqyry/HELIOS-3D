---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import StatCard from '../components/StatCard.astro';
import HopfionScene from '../components/r3f/HopfionScene';
import ClaimsTable from '../components/ClaimsTable.astro';
import LiteratureTimeline from '../components/charts/LiteratureTimeline';
import StageBadge, { type DocStage } from '../components/StageBadge.astro';

const highlights: Array<{ doc: string; stage: DocStage; claim: string; href: string }> = [
  { doc: 'Core Architecture', stage: 'speculative', claim: 'MCA + BRC dual-core, hopfion-based', href: '/docs/speculative/core-architecture/' },
  { doc: 'Candidate Materials', stage: 'established', claim: 'EuS / Bi₂Se₃ / EuS, FGT, Mn₃Sn', href: '/docs/established/candidate-materials-and-mechanisms/' },
  { doc: 'Performance Floor', stage: 'current', claim: '40–60 ps write, pJ/µm² energy floor', href: '/docs/current/targets-comparators-and-projections/' },
  { doc: 'Chiral Sensing', stage: 'speculative', claim: 'CISS, TOHE, peptide-crystal interface', href: '/docs/speculative/defensive-framework/' },
];

const readingPath: Array<{ step: number; title: string; desc: string; stage: DocStage; href: string }> = [
  { step: 1, title: 'Abstract', desc: 'Project pitch and dual-core architecture.', stage: 'established', href: '/docs/established/abstract/' },
  { step: 2, title: 'Candidate Materials', desc: 'Spin textures and the EuS/Bi₂Se₃/EuS substrate.', stage: 'established', href: '/docs/established/candidate-materials-and-mechanisms/' },
  { step: 3, title: 'Literature Review', desc: 'The 2026 evidence base.', stage: 'established', href: '/docs/established/literature-review/' },
  { step: 4, title: 'Claims Matrix', desc: 'What is and is not demonstrated.', stage: 'current', href: '/docs/current/claims-matrix/' },
  { step: 5, title: 'Pitch Deck Outline', desc: 'The full project narrative.', stage: 'speculative', href: '/docs/speculative/pitch-deck-outline/' },
];
---
<BaseLayout title="HELIOS-3D" showSidebar={false} snap={true}>
  {/* Section 1 — Hero */}
  <section class="min-h-screen flex flex-col justify-center py-16 animate-fade-in-up">
    <SectionHeading number="01" title="Hero" />
    <div class="grid md:grid-cols-5 gap-12 items-center">
      <div class="md:col-span-3 flex flex-col justify-center">
        <h1 class="text-6xl font-extrabold leading-[1.1] mb-6 tracking-tight">
          A spintronic coprocessor<br />
          <span class="gradient-text-amber drop-shadow-[0_0_20px_rgba(255,182,39,0.15)]">architecture using 3D hopfions.</span>
        </h1>
        <p class="text-lg text-parchment-2/90 max-w-2xl mb-10 leading-relaxed">
          HELIOS-3D is a staged research hypothesis for an ultra-low-energy thermodynamic inference coprocessor, utilizing 3D spin configurations for nanoscale high-frequency computation.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/start-here/" class="px-6 py-3.5 rounded-lg bg-gradient-to-r from-amber to-ember text-obsidian font-extrabold shadow-[0_4px_20px_rgba(255,107,26,0.25)] hover:shadow-[0_4px_30px_rgba(255,107,26,0.45)] hover:scale-[1.03] transition-all duration-300">
            Start here →
          </a>
          <a href="/docs/current/claims-matrix/" class="px-6 py-3.5 rounded-lg border border-amber/70 text-amber font-semibold hover:bg-amber/5 hover:border-amber hover:scale-[1.03] transition-all duration-300">
            Read the claims →
          </a>
          <a href="/figures/" class="px-6 py-3.5 rounded-lg border border-obsidian-3/60 text-parchment-2 hover:text-parchment hover:border-parchment-2 hover:scale-[1.03] transition-all duration-300">
            See the 3D →
          </a>
        </div>
      </div>
      <div class="md:col-span-2">
        <div class="glass-card p-3 rounded-2xl relative overflow-hidden shadow-2xl">
          <div class="absolute inset-0 bg-gradient-to-tr from-ember/5 to-transparent pointer-events-none"></div>
          <HopfionScene client:visible height="h-[28rem]" />
        </div>
      </div>
    </div>
  </section>

  {/* Section 2 — Why now */}
  <section class="min-h-screen flex flex-col justify-center py-16">
    <SectionHeading number="02" title="The thermodynamic crisis is the motivation" color="cyan-2" />
    <h2 class="text-3xl font-extrabold max-w-4xl mb-12 leading-relaxed">
      IEA projects AI infrastructure will consume <span class="gradient-text-cyan">~600 TWh in 2026</span>, with &gt;4 billion m³ of water withdrawal by 2027. Embodied carbon is now 50% of AI hardware lifecycle footprint.
    </h2>
    <div class="grid md:grid-cols-2 gap-8">
      <StatCard stat="600" unit="TWh" label="AI infrastructure electricity demand in 2026" source="IEA 2024/2026 Projections" tag="DEMONSTRATED" />
      <StatCard stat="4" unit="billion m³" label="Annual AI water withdrawal by 2027" source="Ren et al. (2025)" tag="DEMONSTRATED" />
    </div>
    <div class="mt-12">
      <a href="/docs/established/literature-review/" class="inline-block px-6 py-3 rounded-lg border border-cyan-2/70 text-cyan-2 font-semibold hover:bg-cyan-2/5 hover:border-cyan-2 hover:scale-[1.02] transition-all duration-300">
        Read the evidence →
      </a>
    </div>
  </section>

  {/* Section 3 — Evidence dashboard */}
  <section class="min-h-screen flex flex-col justify-center py-16">
    <SectionHeading number="03" title="Evidence structure" color="ember" />
    <p class="text-lg text-parchment-2/90 max-w-3xl mb-8 leading-relaxed">
      Key highlights across the four development stages. Filter the interactive claims matrix below.
    </p>
    <div class="grid md:grid-cols-2 gap-6 mb-10">
      {highlights.map((h) => (
        <a href={h.href} class="glass-card block rounded-xl p-6 relative group overflow-hidden">
          <div class="absolute -right-6 -top-6 w-20 h-20 bg-ember/5 rounded-full blur-xl group-hover:bg-ember/10 transition-colors duration-300"></div>
          <div class="flex items-center justify-between mb-4">
            <StageBadge stage={h.stage} size="sm" />
          </div>
          <h3 class="text-amber font-bold text-lg mb-2 group-hover:text-ember transition-colors">{h.doc}</h3>
          <p class="text-sm text-parchment-2/90 leading-relaxed">{h.claim}</p>
        </a>
      ))}
    </div>
    <ClaimsTable rows={[
      { claim: 'Hopfion annihilation > 50kBT in EuS/Bi₂Se₃/EuS', tag: 'INFERRED', source: 'Literature Review' },
      { claim: 'Planar-first, electrical read is the minimum credible path', tag: 'INFERRED', source: 'Alternative Materials' },
      { claim: 'DISH enables sub-second 3D scaffolding with 19µm resolution', tag: 'PROPOSED', source: 'Literature Review' },
      { claim: 'Sub-Landauer computation is achievable', tag: 'SPECULATIVE', source: 'Abstract' },
      { claim: '40-ps write at 1.7 pJ/µm² in Mn₃Sn', tag: 'DEMONSTRATED', source: 'Literature Review' },
      { claim: 'TOHE is unambiguous 3D-hopfion electrical hallmark', tag: 'INFERRED', source: 'Literature Review' },
    ]} />
    <div class="mt-8">
      <a href="/docs/current/claims-matrix/" class="inline-block px-6 py-3.5 rounded-lg bg-gradient-to-r from-amber to-ember text-obsidian font-bold shadow-[0_4px_25px_rgba(255,107,26,0.2)] hover:shadow-[0_4px_30px_rgba(255,107,26,0.4)] hover:scale-[1.02] transition-all duration-300">
        See the full claims matrix →
      </a>
    </div>
  </section>

  {/* Section 4 — 2026 evidence */}
  <section class="min-h-screen flex flex-col justify-center py-16">
    <SectionHeading number="04" title="2026 evidence base" color="violet" />
    <p class="text-lg text-parchment-2/90 max-w-3xl mb-8 leading-relaxed">
      Recent literature and experimental constraints driving the coprocessor architecture.
    </p>
    <div class="glass-card p-6 rounded-2xl overflow-hidden shadow-2xl">
      <div class="overflow-x-auto">
        <LiteratureTimeline client:visible />
      </div>
    </div>
    <div class="mt-12">
      <a href="/docs/established/literature-review/" class="inline-block px-6 py-3 rounded-lg border border-violet/70 text-violet font-semibold hover:bg-violet/5 hover:border-violet hover:scale-[1.02] transition-all duration-300">
        Read the full literature review →
      </a>
    </div>
  </section>

  {/* Section 5 — Reading path */}
  <section class="min-h-screen flex flex-col justify-center py-16">
    <SectionHeading number="05" title="Where to start" color="parchment-2" />
    <p class="text-lg text-parchment-2/90 max-w-3xl mb-12 leading-relaxed">
      A structured reading path designed to step from foundational physics to speculation.
    </p>
    <ol class="space-y-4 mb-12">
      {readingPath.map((p) => (
        <li class="glass-card rounded-xl p-5 hover:border-amber/35 flex items-center justify-between gap-6 group">
          <div class="flex items-center gap-6">
            <span class="font-mono text-3xl font-bold text-amber/30 group-hover:text-amber transition-colors duration-300 w-12">{String(p.step).padStart(2, '0')}</span>
            <div>
              <a href={p.href} class="text-xl font-bold text-amber hover:text-ember transition-colors">{p.title}</a>
              <p class="mt-1 text-sm text-parchment-2/90 leading-relaxed">{p.desc}</p>
            </div>
          </div>
          <StageBadge stage={p.stage} size="sm" />
        </li>
      ))}
    </ol>
    <a href="/start-here/" class="inline-block px-8 py-4 rounded-lg bg-gradient-to-r from-amber to-ember text-obsidian font-extrabold shadow-[0_4px_25px_rgba(255,107,26,0.25)] hover:shadow-[0_4px_35px_rgba(255,107,26,0.45)] hover:scale-[1.03] transition-all duration-300">
      Start here →
    </a>
  </section>
</BaseLayout>
